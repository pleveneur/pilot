{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Pilot",
  "version": "0.1.0",
  "identifier": "com.pilot.editor",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": null
    }
  },
  "build": {
    "beforeDevCommand": "npm run build:handbook && npm run dev",
    "beforeBuildCommand": "npm run build:handbook && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pilot",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
